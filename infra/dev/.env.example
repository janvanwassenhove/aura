# AURA — Environment Variables
# Copy this file to .env and fill in values, or better: run the setup wizard,
# which generates a complete .env interactively:
#
#     uv run python -m aura_brain.wizard
#
# All defaults are set for FakeRobot + mock M365 — no credentials required for
# local dev.

# ===========================================================================
# Robot (the Reachy Mini / Pi side)
# ===========================================================================
# Options: fake | reachy
# Use "fake" for all development. "reachy" requires a physical Reachy Mini.
ROBOT_ADAPTER=fake

# Where robot-runtime runs. In docker compose this is overridden to the
# in-network name; for the two-host setup point it at the Pi:
# ROBOT_RUNTIME_URL=http://reachy.local:8001
IDLE_INTERVAL_SECONDS=4

# ===========================================================================
# LLM Provider
# ===========================================================================
# Options: openai | openrouter | gemini | echo
# "echo" requires no key and mirrors input back — pure offline dev.
LLM_PROVIDER=openai

# --- OpenAI ---
# Required when LLM_PROVIDER=openai, STT_PROVIDER=openai_realtime, or TTS_PROVIDER=openai.
# Written without '=' so docker/podman --env-file inherits the value from the
# host environment rather than setting an empty string.
# To hard-code a value instead, write: OPENAI_API_KEY=sk-...
OPENAI_API_KEY
OPENAI_MODEL=gpt-4o-mini

# Optional: point the OpenAI client at an OpenAI-COMPATIBLE proxy instead of
# api.openai.com. Leave unset for real OpenAI.
# OPENAI_BASE_URL=http://localhost:8080/v1

# --- OpenRouter ---
# Required when LLM_PROVIDER=openrouter. Same no-'=' rule as OPENAI_API_KEY.
OPENROUTER_API_KEY
# Free models (as of Apr 2026): openai/gpt-oss-120b:free, openai/gpt-oss-20b:free,
# google/gemma-4-31b-it:free, nvidia/nemotron-3-super-120b-a12b:free, ...
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# --- Gemini ---
# Required when LLM_PROVIDER=gemini. Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Number of session turns to include in LLM context
MAX_CONTEXT_TURNS=10

# ===========================================================================
# Voice Pipeline
# ===========================================================================
# STT options: null | local_whisper | openai_realtime
#   "null" = text-only (console). "local_whisper" runs offline.
#   "openai_realtime" uses the GA Realtime speech-to-speech transport (U22).
STT_PROVIDER=null

# Whisper model size when STT_PROVIDER=local_whisper: tiny | base | small | medium
LOCAL_WHISPER_MODEL=tiny

# TTS options: null | kokoro | piper | openai   (kokoro/piper run offline)
TTS_PROVIDER=null
LOCAL_TTS_BACKEND=kokoro

# ===========================================================================
# Offline resilience
# ===========================================================================
# Heartbeat watches the brain↔robot link + upstream internet; on failure the
# pipeline degrades to the offline tier (local model → regex fallback).
HEARTBEAT_ENABLED=true
# Optional URL the heartbeat pings to detect internet loss (e.g. the LLM API)
# UPSTREAM_HEALTH_URL=https://api.openai.com/v1

# Local OpenAI-compatible server used for turns while OFFLINE (ollama /
# llama.cpp on the laptop). Unset → regex fallback only.
# OFFLINE_LLM_BASE_URL=http://localhost:11434/v1
OFFLINE_LLM_MODEL=llama3.1

# ===========================================================================
# Security & knowledge layer (ADR-008)
# ===========================================================================
# Passphrase for the encrypted person-knowledge store (AES-256-GCM envelope
# encryption, per-person keys). Set → profiles persist encrypted at
# KNOWLEDGE_DB_PATH and the SENSITIVE tier unlocks at boot.
# Unset → in-memory only: profiles are lost on restart, nothing hits disk.
# The setup wizard can generate this section for you.
KNOWLEDGE_PASSPHRASE=
# Per-install random salt for key derivation (the wizard generates one).
KNOWLEDGE_SALT=
# Ciphertext store location (compose default: /data/knowledge.enc.json)
# KNOWLEDGE_DB_PATH=./data/knowledge.enc.json

# Webhook that pushes step-up approval requests to your phone for DESTRUCTIVE
# knowledge operations (delete fact / forget person) while encrypted.
# Unset → destructive ops are auto-denied (fail closed).
STEP_UP_WEBHOOK_URL=

# Outbound dev agent (U20): lets AURA read/write repos with approval gating.
# Off by default; writes/commits/pushes always require explicit approval.
DEV_AGENT_ENABLED=false

# ===========================================================================
# M365 / Work IQ MCP Connector
# ===========================================================================
# Options: mock | workiq
# "mock" returns realistic fake M365 data; no credentials required.
M365_CONNECTOR=mock

# Comma-separated connectors to enable: m365, google, github, slack
# Connectors with missing credentials start 'unauthenticated' (graceful).
ENABLED_CONNECTORS=m365

# Azure Entra App Registration (required when M365_CONNECTOR=workiq)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
# Agent 365 service principal (do not change unless Microsoft updates it)
AZURE_SP_ID=ea9ffc3e-8a23-4a7d-836d-234d7c7565c1
# Per-user Microsoft token (managed at runtime via Device Code flow — do NOT set manually)
M365_USER_ACCESS_TOKEN=

# Google OAuth client secrets JSON path (when google is enabled)
GOOGLE_CLIENT_SECRETS_FILE=
# GitHub PAT (when github is enabled; scopes: read:user, repo)
GITHUB_TOKEN=
# Slack bot token (when slack is enabled)
SLACK_BOT_TOKEN=

# Keyring passphrase — encrypts token storage for Docker/headless environments.
# Leave empty for local dev (uses the OS-native keyring instead).
KEYRING_PASSPHRASE=

# ===========================================================================
# Orchestrator
# ===========================================================================
# Startup mode: work | home | presentation | silent_desk | demo
ACTIVE_PERSONA=work
# Seconds before an unanswered approval request auto-cancels
APPROVAL_TIMEOUT_SECONDS=30

# ===========================================================================
# Memory
# ===========================================================================
MEMORY_STORE=sqlite
SQLITE_PATH=/data/aura.db
SESSION_RETENTION_DAYS=30
REMINDER_CHECK_INTERVAL=10
