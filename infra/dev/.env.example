# AURA — Development Environment Variables
# Copy this file to .env and fill in values as needed.
# All defaults are set for FakeRobot + mock M365 — no credentials required for local dev.

# ===========================================================================
# Robot Adapter
# ===========================================================================
# Options: fake | reachy
# Use "fake" for all development. "reachy" requires a physical Reachy Mini on the network.
ROBOT_ADAPTER=fake

# Seconds between idle motion sequences when robot is in IDLE state
IDLE_INTERVAL_SECONDS=4

# ===========================================================================
# Voice Pipeline — STT (Speech-to-Text)
# ===========================================================================
# Options: openai_realtime | local_whisper
# "openai_realtime" requires OPENAI_API_KEY and internet access.
# "local_whisper" runs fully offline using the whisper.cpp model.
STT_PROVIDER=local_whisper

# Whisper model size (used when STT_PROVIDER=local_whisper)
# Options: tiny | base | small | medium | large
# "tiny" is fastest; "base" is recommended for production-grade accuracy.
LOCAL_WHISPER_MODEL=tiny

# ===========================================================================
# Voice Pipeline — TTS (Text-to-Speech)
# ===========================================================================
# Options: openai | kokoro | piper
# "openai" requires OPENAI_API_KEY and internet access.
# "kokoro" and "piper" run fully offline.
TTS_PROVIDER=kokoro

# TTS backend when TTS_PROVIDER is a local option (kokoro or piper)
LOCAL_TTS_BACKEND=kokoro

# ===========================================================================
# LLM Provider
# ===========================================================================
# Options: openai | anthropic | ollama | openrouter | gemini | echo
# "echo" requires no key and mirrors input back — useful for pure offline dev.
# "ollama" runs a LOCAL model (offline / privacy-sensitive turns).
# All providers support tool-calling through the orchestrator.
LLM_PROVIDER=openai

# ===========================================================================
# OpenAI
# ===========================================================================
# Required when STT_PROVIDER=openai_realtime, TTS_PROVIDER=openai, or LLM_PROVIDER=openai.
# Written without '=' so podman/docker --env-file inherits the value from the
# host environment (system/user env var) rather than setting an empty string.
# To hard-code a value instead, write: OPENAI_API_KEY=sk-...
OPENAI_API_KEY

# LLM model used by the orchestrator when LLM_PROVIDER=openai
OPENAI_MODEL=gpt-4o-mini

# Optional: point the OpenAI client at an OpenAI-COMPATIBLE proxy instead of
# api.openai.com. This is how to front a ChatGPT/Copilot subscription (which
# expose no direct API) — run a local bridge that speaks the OpenAI protocol and
# set this to its URL. Leave unset for real OpenAI.
# OPENAI_BASE_URL=http://localhost:8080/v1

# ===========================================================================
# Anthropic (Claude)
# ===========================================================================
# Required when LLM_PROVIDER=anthropic. Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY
# Default Claude model (claude-opus-4-8 | claude-sonnet-4-6 | claude-haiku-4-5-20251001)
ANTHROPIC_MODEL=claude-sonnet-4-6

# ===========================================================================
# Ollama (local model)
# ===========================================================================
# Used when LLM_PROVIDER=ollama. Run `ollama serve` on the laptop (the brain
# host) — NOT on the Pi. No API key needed.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ===========================================================================
# OpenRouter
# ===========================================================================
# Required when LLM_PROVIDER=openrouter.
# Same rule as OPENAI_API_KEY — written without '=' so the host env var wins.
# To hard-code a value instead, write: OPENROUTER_API_KEY=sk-or-...
OPENROUTER_API_KEY

# Default model when LLM_PROVIDER=openrouter.
# Free models (as of Apr 2026) — all priced at $0/M tokens:
#   openai/gpt-oss-120b:free      — 131K ctx, strong reasoning + tool use
#   openai/gpt-oss-20b:free       — 131K ctx, fast, low-latency
#   google/gemma-4-31b-it:free    — 262K ctx, multilingual, function calling
#   google/gemma-4-26b-a4b-it:free — 262K ctx, MoE, multimodal
#   nvidia/nemotron-3-super-120b-a12b:free — 262K ctx, #5 programming
#   tencent/hy3-preview:free      — 262K ctx, #2 programming, agentic
#   minimax/minimax-m2.5:free     — 197K ctx, office/agent tasks
#   poolside/laguna-m.1:free      — 131K ctx, coding agent specialist
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# ===========================================================================
# Gemini
# ===========================================================================
# Required when LLM_PROVIDER=gemini.
# Obtain from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Default Gemini model when LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.5-flash

# Number of session turns to include in LLM context
MAX_CONTEXT_TURNS=10

# ===========================================================================
# M365 / Work IQ MCP Connector
# ===========================================================================
# Options: mock | workiq
# "mock" returns realistic fake M365 data; no credentials required.
# "workiq" calls real Work IQ MCP servers; requires AZURE_* credentials below.
M365_CONNECTOR=mock

# Comma-separated list of connectors to enable at startup.
# Available: m365, google, github, slack
# Connectors with missing credentials start in 'unauthenticated' state (graceful).
ENABLED_CONNECTORS=m365

# Azure Entra App Registration credentials (required when M365_CONNECTOR=workiq)
# Obtain from https://portal.azure.com → App Registrations
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# Agent 365 service principal (do not change unless Microsoft updates it)
AZURE_SP_ID=ea9ffc3e-8a23-4a7d-836d-234d7c7565c1

# Per-user Microsoft access token (managed at runtime by identity-service via
# Device Code flow — do NOT set this manually in production)
M365_USER_ACCESS_TOKEN=

# Google OAuth client credentials (required when google is in ENABLED_CONNECTORS)
# Obtain from https://console.cloud.google.com → APIs & Services → Credentials
# Download the JSON and set the path here:
GOOGLE_CLIENT_SECRETS_FILE=

# GitHub personal access token (required when github is in ENABLED_CONNECTORS)
# Obtain from https://github.com/settings/tokens (read:user, repo)
GITHUB_TOKEN=

# Slack bot token (required when slack is in ENABLED_CONNECTORS)
# Obtain from https://api.slack.com/apps → OAuth & Permissions
SLACK_BOT_TOKEN=

# Keyring passphrase — encrypts token storage for Docker/headless environments.
# Leave empty for local dev (uses OS native keyring: Windows Credential Manager /
# macOS Keychain / GNOME Keyring instead). Required when KEYRING_BACKEND=cryptfile.
KEYRING_PASSPHRASE=

# ===========================================================================
# Orchestrator
# ===========================================================================
# Active persona mode
# Options: work | home | presentation | silent_desk | demo
ACTIVE_PERSONA=work

# Seconds before an unanswered approval request auto-cancels
APPROVAL_TIMEOUT_SECONDS=30

# ===========================================================================
# Memory Service
# ===========================================================================
# Options: sqlite (only)
MEMORY_STORE=sqlite

# Path to SQLite database file (relative to memory-service container)
SQLITE_PATH=/data/aura.db

# How many days of session history to retain before cleanup
SESSION_RETENTION_DAYS=30

# How often (seconds) the reminder scheduler checks for due reminders
REMINDER_CHECK_INTERVAL=10

# ===========================================================================
# Offline Fallback
# ===========================================================================
# Seconds the heartbeat monitor waits between pings
# HEARTBEAT_INTERVAL_SECONDS=30

# Number of consecutive heartbeat failures before entering DEGRADED mode
# HEARTBEAT_FAILURE_THRESHOLD=3

# Seconds the system must be stable in RECOVERING before returning to ONLINE
# RECOVERY_STABILITY_WINDOW_SECONDS=30

# ===========================================================================
# OpenClaw Gateway (Spec 012)
# ===========================================================================
# API keys are stored in memory-service; this is the per-key rate limit
# GATEWAY_RATE_LIMIT_PER_SECOND=10
