{
  "name": "aura-desktop",
  "version": "1.0.0",
  "description": "AURA desktop app \u2014 brain + operator console in one window",
  "author": {
    "name": "Jan Van Wassenhove",
    "email": "janvanwassenhove@users.noreply.github.com"
  },
  "homepage": "https://github.com/janvanwassenhove/aura",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build:console": "cd ../operator-console && npm run build",
    "dist": "npm run build:console && electron-builder --win nsis"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "dev.aura.desktop",
    "productName": "AURA",
    "files": [
      "main.cjs",
      "preload.cjs",
      "updater.cjs",
      "build/**"
    ],
    "extraResources": [
      {
        "from": "../operator-console/dist",
        "to": "console"
      },
      {
        "from": "../../pyproject.toml",
        "to": "aura/pyproject.toml"
      },
      {
        "from": "../../uv.lock",
        "to": "aura/uv.lock"
      },
      {
        "from": "../../packages",
        "to": "aura/packages",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/tests/**"
        ]
      },
      {
        "from": "../../services",
        "to": "aura/services",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/tests/**"
        ]
      },
      {
        "from": "../../apps/aura-brain",
        "to": "aura/apps/aura-brain",
        "filter": [
          "**/*",
          "!**/__pycache__/**",
          "!**/.pytest_cache/**",
          "!**/tests/**"
        ]
      },
      {
        "from": "../../infra",
        "to": "aura/infra",
        "filter": [
          "**/*",
          "!**/.env"
        ]
      }
    ],
    "artifactName": "AURA-${version}-${os}-${arch}.${ext}",
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "AURA",
      "artifactName": "AURA-${version}-windows-setup.${ext}"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "build/icon.png",
      "identity": null,
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/icon.png",
      "category": "Utility",
      "synopsis": "AURA - embodied AI assistant for Reachy Mini"
    }
  }
}
