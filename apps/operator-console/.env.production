# Desktop-app topology: EVERYTHING is served by the aura-brain on :8020
# (8000 is squatted by Pollen's "Reachy Mini Control" app). Baked into every
# `npm run build` so a plain build always produces a working desktop console.
# Dev against other hosts: override via a local .env.production.local.
VITE_BRAIN_URL=http://localhost:8020
VITE_ORCHESTRATOR_URL=http://localhost:8020
VITE_CONVERSATION_URL=http://localhost:8020
VITE_CONNECTOR_URL=http://localhost:8020
VITE_IDENTITY_URL=http://localhost:8020
VITE_ROBOT_RUNTIME_WS=ws://localhost:8020/ws/events
