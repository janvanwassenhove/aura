FROM node:20-alpine
WORKDIR /app

ARG VITE_ORCHESTRATOR_URL=http://localhost:8003
ARG VITE_ROBOT_RUNTIME_WS=ws://localhost:8001/ws/events
ARG VITE_ORCHESTRATOR_WS=ws://localhost:8003/ws/events
ARG VITE_IDENTITY_URL=http://localhost:8006
ARG VITE_CONNECTOR_URL=http://localhost:8004

ENV VITE_ORCHESTRATOR_URL=$VITE_ORCHESTRATOR_URL
ENV VITE_ROBOT_RUNTIME_WS=$VITE_ROBOT_RUNTIME_WS
ENV VITE_ORCHESTRATOR_WS=$VITE_ORCHESTRATOR_WS
ENV VITE_IDENTITY_URL=$VITE_IDENTITY_URL
ENV VITE_CONNECTOR_URL=$VITE_CONNECTOR_URL

COPY package.json .
RUN npm install
COPY . .

EXPOSE 5173
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "5173"]
